# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Gmail SMTP Configuration
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Database Connection (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:your-db-password@db.xxxxxx.supabase.co:5432/postgres?sslmode=require

# JWT Cryptographic Secret
JWT_SECRET=your-64-character-random-jwt-secret-key-goes-here

# Cloudflare R2 Config
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=linuxquest-images
R2_PUBLIC_URL=https://pub-xxxxxx.r2.dev

# Server Environment Configuration
PORT=8080
ENV=development
FRONTEND_URL=http://localhost:5173
